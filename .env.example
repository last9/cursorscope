PORT=4327

# Auto-start ingestor from Cursor hooks (set false to require manual npm start)
CURSORSCOPE_AUTO_START=true
# Override install location for global hooks (default: ~/.cursorscope after `cursorscope setup`)
# CURSORSCOPE_HOME=/Users/you/.cursorscope

# Ingestor OTLP destinations (direct export from Node service)
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:4318/v1/logs
OTEL_EXPORTER_OTLP_HEADERS=
# Last9 expects cumulative counters for OTLP metrics
OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=cumulative

# Last9: use cumulative counters (set on exporter env if your backend requires it)
# OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=cumulative

# Service identity in Last9 (use "cursor" if you want one service name across tools)
OTEL_SERVICE_NAME=cursorscope
OTEL_SERVICE_NAMESPACE=cursorscope
OTEL_SERVICE_VERSION=0.2.0
DEPLOYMENT_ENVIRONMENT=local
DEBUG_OTEL=false

# Privacy: set true to include full prompt text in logs/spans
CURSOR_LOG_USER_PROMPTS=false
# Include tool_input/tool_output in logs when redacting (still redacts secrets)
CURSOR_LOG_TOOL_DETAILS=false
# Mask cursor.user.email span attribute as ***@*** before exporting to OTLP backend
CURSOR_MASK_USER_EMAIL=false
# Estimate context tokens for MCP, shell/CLI, skills, and tools (chars/4). Not Cursor LLM billing.
CURSOR_TRACK_ATTRIBUTED_TOKENS=true

# OTel GenAI semconv: opt into latest experimental GenAI trace attributes in downstream SDKs
# OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental
# Opt-in: record gen_ai.tool.call.arguments / result on execute_tool spans (redacted; max bytes below)
# CURSOR_LOG_TOOL_DETAILS=false
# CURSOR_TOOL_PAYLOAD_MAX_LEN=8192

# Optional Cursor Admin API polling (team daily usage gauges)
ENABLE_CURSOR_API_POLLING=false
CURSOR_API_BASE_URL=https://api.cursor.com
CURSOR_ADMIN_API_KEY=
CURSOR_TEAM_ID=
CURSOR_API_POLL_INTERVAL_MS=300000

# Hook forwarder destination
CURSOR_HOOK_ENDPOINT=http://localhost:4327/cursor/hooks

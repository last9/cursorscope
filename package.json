{
  "name": "@last9/cursorscope",
  "version": "0.3.0",
  "description": "Export Cursor IDE usage to OpenTelemetry (traces, metrics, logs) for backends like Last9",
  "license": "MIT",
  "type": "module",
  "bin": {
    "cursorscope": "./bin/cursorscope.js"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    ".env.example",
    "otel",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/last9/cursorscope.git"
  },
  "scripts": {
    "setup": "node bin/cursorscope.js setup",
    "setup:last9": "node bin/cursorscope.js setup --last9",
    "start": "node --env-file=.env src/server.js",
    "start:bg": "scripts/ensure-cursorscope.sh",
    "stop": "scripts/stop-cursorscope.sh",
    "restart": "scripts/stop-cursorscope.sh && scripts/ensure-cursorscope.sh",
    "install:global-hooks": "scripts/install-global-hooks.sh",
    "uninstall:global-hooks": "scripts/uninstall-global-hooks.sh",
    "dev": "node --env-file=.env --watch src/server.js",
    "test": "node scripts/run-tests.mjs",
    "test:watch": "node --test --watch test/*.test.js",
    "lint": "node scripts/lint.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.205.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.205.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.205.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.205.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-logs": "^0.205.0",
    "@opentelemetry/sdk-metrics": "^2.1.0",
    "@opentelemetry/sdk-trace-base": "^2.1.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2"
  }
}
